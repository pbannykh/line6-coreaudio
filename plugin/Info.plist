<?xml version="1.0" encoding="UTF-8"?>
<!--
  Info.plist for the Line 6 CoreAudio HAL plugin.
  The Line6.driver bundle is installed in /Library/Audio/Plug-Ins/HAL/ and
  loaded by coreaudiod. The Line6_Create factory is registered under the
  AudioServerPlugIn type UUID.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>Line6HAL</string>
    <key>CFBundleIdentifier</key>
    <string>org.line6.Line6HAL</string>
    <key>CFBundleName</key>
    <string>Line6</string>
    <key>CFBundlePackageType</key>
    <string>BNDL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Plugin factory: UUID -> C function name -->
    <key>CFPlugInFactories</key>
    <dict>
        <key>4D47D4D8-18E3-47CD-9A21-1DC61F2036D6</key>
        <string>Line6_Create</string>
    </dict>

    <!-- AudioServerPlugIn type -> our factory -->
    <key>CFPlugInTypes</key>
    <dict>
        <key>443ABAB8-E7B3-491A-B985-BEB9187030DB</key>
        <array>
            <string>4D47D4D8-18E3-47CD-9A21-1DC61F2036D6</string>
        </array>
    </dict>
</dict>
</plist>
